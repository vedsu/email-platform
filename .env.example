# ============================================================
# Email Platform — Environment Configuration
# Copy to .env and fill in values. Never commit .env itself.
# Localhost defaults are pre-filled; update for production.
# ============================================================

# ── General ──────────────────────────────────────────────────
APP_ENV=localhost                     # localhost | production
APP_DEBUG=true                        # false in production
APP_SECRET_KEY=change-me-to-random-64-chars
APP_DOMAIN=localhost                  # yourdomain.com in production

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2                         # increase on server (4–8)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=email_platform
MONGO_USER=
MONGO_PASSWORD=
# Full URI (overrides above if set)
MONGO_URI=mongodb://localhost:27017/email_platform

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URI=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=4                  # increase on server (8–16)

# ── Postal (mail engine) ────────────────────────────────────
POSTAL_API_URL=http://localhost:5000  # https://postal.yourdomain.com in production
POSTAL_API_KEY=
POSTAL_WEBHOOK_SECRET=
POSTAL_WEB_HOST=postal.localhost      # postal.yourdomain.com in production

# ── Postal internals (MariaDB + RabbitMQ) ───────────────────
POSTAL_MARIADB_HOST=mariadb
POSTAL_MARIADB_PORT=3306
POSTAL_MARIADB_ROOT_PASSWORD=postal_root_pass  # strong password in production
POSTAL_MARIADB_DATABASE=postal
POSTAL_RABBITMQ_HOST=rabbitmq
POSTAL_RABBITMQ_PORT=5672
POSTAL_RABBITMQ_USER=postal
POSTAL_RABBITMQ_PASSWORD=postal_pass           # strong password in production
POSTAL_RABBITMQ_VHOST=/postal

# ── Mail Catcher (localhost only) ────────────────────────────
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Sending Streams (subdomain per stream) ──────────────────
STREAM_OPTIN_DOMAIN=mail.localhost        # mail.yourdomain.com
STREAM_ENGAGED_DOMAIN=eng.localhost       # eng.yourdomain.com
STREAM_COLD_DOMAIN=out.localhost          # out.yourdomain.com

# ── Warmup ───────────────────────────────────────────────────
WARMUP_ENABLED=true
WARMUP_OPTIN_DAILY_CAP=500           # starting cap, ramps up
WARMUP_ENGAGED_DAILY_CAP=200
WARMUP_COLD_DAILY_CAP=100
WARMUP_RAMP_PERCENT=20               # daily increase %
WARMUP_MAX_BOUNCE_RATE=5.0           # % — pause if exceeded
WARMUP_MAX_COMPLAINT_RATE=0.3        # % — pause if exceeded

# ── Suppression ──────────────────────────────────────────────
SUPPRESSION_HARD_BOUNCE=true          # auto-suppress on hard bounce
SUPPRESSION_COMPLAINT=true            # auto-suppress on complaint
SUPPRESSION_UNSUBSCRIBE=true          # auto-suppress on unsub

# ── Claude API (intelligence layer) ─────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_REQUIRE_HUMAN_APPROVAL=true    # never set false for bulk ops

# ── S3 / Object Storage (deferred — not needed for core) ────
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ── CRM / Team ──────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=
JWT_SECRET_KEY=change-me-to-random-64-chars
JWT_EXPIRY_HOURS=24

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=DEBUG                       # INFO in production
LOG_FORMAT=json
